generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  role        String    @default("business_admin")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")
  workspaceAccess AdminWorkspaceAccess[]
  activityEvents  ActivityEvent[]

  @@map("admin_users")
}

model AdminWorkspaceAccess {
  id          String    @id @default(cuid())
  adminUserId String    @map("admin_user_id")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([adminUserId, workspaceId])
  @@map("admin_workspace_access")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  workspaces Workspace[]
}

model Workspace {
  id                 String                    @id @default(cuid())
  name               String
  ownerId            String
  owner              User                      @relation(fields: [ownerId], references: [id])
  accountType        String                    @default("demo") @map("account_type")
  plan               String                    @default("Demo Free")
  billingStatus      String                    @default("mock_billing") @map("billing_status")
  billingInterval    String                    @default("monthly") @map("billing_interval")
  monthlyPricePence  Int                       @default(0) @map("monthly_price_pence")
  active             Boolean                   @default(true)
  setupCompletedAt   DateTime?                 @map("setup_completed_at")
  replyNotificationEmail String?                @map("reply_notification_email")
  locations          Location[]
  brandVoiceSettings BrandVoiceSetting[]
  integrations       Integration[]
  googleConnection   GoogleBusinessConnection?
  subscription       Subscription?
  usageEvents        UsageEvent[]
  activityEvents     ActivityEvent[]
  adminAccess        AdminWorkspaceAccess[]
  savedReplies       SavedReply[]
  createdAt          DateTime                  @default(now())
}

model Location {
  id                   String    @id @default(cuid())
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  businessName         String
  businessType         String
  address              String?
  city                 String
  phone                String?
  website              String?
  googleRating         Float?
  googleReviewCount    Int?
  priceRange           String?
  googleBusinessStatus String    @default("Google Business Profile integration coming soon")
  googlePlaceId        String?   @map("google_place_id")
  googleAccountId      String?   @map("google_account_id")
  googleLocationId     String?   @map("google_location_id")
  gbpSyncEnabled       Boolean   @default(false) @map("gbp_sync_enabled")
  lastGbpImportAttemptAt DateTime? @map("last_gbp_import_attempt_at")
  reviews              Review[]
  brandVoiceSetting    BrandVoiceSetting?
  activityEvents       ActivityEvent[]
}

model BrandVoiceSetting {
  id                              String    @id @default(cuid())
  workspaceId                     String
  workspace                       Workspace @relation(fields: [workspaceId], references: [id])
  locationId                      String?   @unique @map("location_id")
  location                        Location? @relation(fields: [locationId], references: [id])
  preferredTone                   String
  defaultLength                   String
  greetingStyle                   String?
  signOffStyle                    String?
  wordsToUse                      String?
  wordsToAvoid                    String?
  complaintHandlingStyle          String?
  useEmojis                       Boolean   @default(false)
  mentionBusinessName             Boolean   @default(true)
  apologiseForPoorExperiences     Boolean   @default(true)
  inviteUnhappyCustomersToContact Boolean   @default(true)
  keepRepliesShortByDefault       Boolean   @default(false)

  @@unique([workspaceId, locationId])
}

model Review {
  id               String           @id @default(cuid())
  locationId       String
  location         Location         @relation(fields: [locationId], references: [id])
  customerName     String?
  starRating       Int
  reviewText       String
  source           String
  status           String
  sentiment        String
  receivedAt       DateTime
  selectedReplyId  String?          @map("selected_reply_id")
  editedReply      String?          @map("edited_reply")
  lastEditedAt     DateTime?        @map("last_edited_at")
  copiedAt         DateTime?        @map("copied_at")
  postedAt         DateTime?        @map("posted_at")
  archivedAt       DateTime?        @map("archived_at")
  actionedByEmail  String?          @map("actioned_by_email")
  generatedReplies GeneratedReply[]
  savedReplies     SavedReply[]
  activityEvents    ActivityEvent[]
}

model GeneratedReply {
  id               String   @id @default(cuid())
  reviewId         String
  review           Review   @relation(fields: [reviewId], references: [id])
  variant          Int
  tone             String
  length           String
  body             String
  generationSource String   @default("fallback") @map("generation_source")
  selected         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SavedReply {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  reviewId    String?
  review      Review?   @relation(fields: [reviewId], references: [id])
  body        String
  tone        String
  category    String
  usageCount  Int       @default(0)
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Integration {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  provider    String
  status      String
  metadata    Json?
  updatedAt   DateTime  @updatedAt
}

model GoogleBusinessConnection {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  googleAccountId String?
  accessToken     String?
  refreshToken    String?
  connected       Boolean   @default(false)
  lastSyncedAt    DateTime?
}

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  plan                 String
  status               String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
}

model UsageEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventType   String
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
}

model Lead {
  id                     String   @id @default(cuid())
  name                   String
  businessName           String   @map("business_name")
  businessType           String   @map("business_type")
  numberOfLocations      Int      @map("number_of_locations")
  email                  String
  mobileNumber           String?  @map("mobile_number")
  currentReviewPlatform  String   @map("current_review_platform")
  averageReviewsPerMonth String   @map("average_reviews_per_month")
  biggestChallenge       String   @map("biggest_challenge")
  status                 String   @default("new")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("leads")
}

model ActivityEvent {
  id          String     @id @default(cuid())
  workspaceId String     @map("workspace_id")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  locationId  String?    @map("location_id")
  location    Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  reviewId    String?    @map("review_id")
  review      Review?    @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  adminUserId String?    @map("admin_user_id")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  eventType   String     @map("event_type")
  summary     String
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("activity_events")
}
