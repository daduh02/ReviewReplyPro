generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  role        String    @default("business_admin")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@map("admin_users")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  workspaces Workspace[]
}

model Workspace {
  id                 String                    @id @default(cuid())
  name               String
  ownerId            String
  owner              User                      @relation(fields: [ownerId], references: [id])
  accountType        String                    @default("demo") @map("account_type")
  plan               String                    @default("Demo Free")
  billingStatus      String                    @default("mock_billing") @map("billing_status")
  billingInterval    String                    @default("monthly") @map("billing_interval")
  monthlyPricePence  Int                       @default(0) @map("monthly_price_pence")
  active             Boolean                   @default(true)
  locations          Location[]
  brandVoiceSettings BrandVoiceSetting[]
  integrations       Integration[]
  googleConnection   GoogleBusinessConnection?
  subscription       Subscription?
  usageEvents        UsageEvent[]
  savedReplies       SavedReply[]
  createdAt          DateTime                  @default(now())
}

model Location {
  id                   String    @id @default(cuid())
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  businessName         String
  businessType         String
  address              String?
  city                 String
  phone                String?
  website              String?
  googleRating         Float?
  googleReviewCount    Int?
  priceRange           String?
  googleBusinessStatus String    @default("Google Business Profile integration coming soon")
  reviews              Review[]
  brandVoiceSetting    BrandVoiceSetting?
}

model BrandVoiceSetting {
  id                              String    @id @default(cuid())
  workspaceId                     String
  workspace                       Workspace @relation(fields: [workspaceId], references: [id])
  locationId                      String?   @unique @map("location_id")
  location                        Location? @relation(fields: [locationId], references: [id])
  preferredTone                   String
  defaultLength                   String
  greetingStyle                   String?
  signOffStyle                    String?
  wordsToUse                      String?
  wordsToAvoid                    String?
  complaintHandlingStyle          String?
  useEmojis                       Boolean   @default(false)
  mentionBusinessName             Boolean   @default(true)
  apologiseForPoorExperiences     Boolean   @default(true)
  inviteUnhappyCustomersToContact Boolean   @default(true)
  keepRepliesShortByDefault       Boolean   @default(false)

  @@unique([workspaceId, locationId])
}

model Review {
  id               String           @id @default(cuid())
  locationId       String
  location         Location         @relation(fields: [locationId], references: [id])
  customerName     String?
  starRating       Int
  reviewText       String
  source           String
  status           String
  sentiment        String
  receivedAt       DateTime
  selectedReplyId  String?          @map("selected_reply_id")
  editedReply      String?          @map("edited_reply")
  lastEditedAt     DateTime?        @map("last_edited_at")
  copiedAt         DateTime?        @map("copied_at")
  postedAt         DateTime?        @map("posted_at")
  archivedAt       DateTime?        @map("archived_at")
  actionedByEmail  String?          @map("actioned_by_email")
  generatedReplies GeneratedReply[]
  savedReplies     SavedReply[]
}

model GeneratedReply {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id])
  variant   Int
  tone      String
  length    String
  body      String
  selected  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedReply {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  reviewId    String?
  review      Review?   @relation(fields: [reviewId], references: [id])
  body        String
  tone        String
  category    String
  usageCount  Int       @default(0)
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Integration {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  provider    String
  status      String
  metadata    Json?
  updatedAt   DateTime  @updatedAt
}

model GoogleBusinessConnection {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  googleAccountId String?
  accessToken     String?
  refreshToken    String?
  connected       Boolean   @default(false)
  lastSyncedAt    DateTime?
}

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  plan                 String
  status               String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
}

model UsageEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventType   String
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
}
