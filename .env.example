DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reviewreply_pro"

# OpenAI is optional. Without this, the app uses MockAIReplyProvider.
OPENAI_API_KEY=""

# Google Business Profile OAuth/API placeholders. Without these, mock sync is used.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# Stripe is optional. Without these, checkout and webhooks use local-safe placeholders.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
