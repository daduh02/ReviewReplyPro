# Local SQLite database used by Prisma CLI and local development.
DATABASE_URL="file:./dev.db"

# Production Turso/libSQL database used by Prisma at runtime on Vercel.
# Get these from Turso:
# turso db show --url <database-name>
# turso db tokens create <database-name>
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Admin Google OAuth
# Google Cloud redirect URI:
# http://localhost:3000/api/auth/google/callback
# Production redirect URI:
# https://your-domain.example/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Optional AI provider
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Google Business Profile OAuth/API placeholders. Connection coming next.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# Optional Stripe provider
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
